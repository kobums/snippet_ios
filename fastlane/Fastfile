default_platform(:ios)

# ---------------------------------------------------------
# SwiftUI 네이티브 앱 배포 (Flutter 아님 — flutter build 없음)
# 버전은 Snippet.xcodeproj/project.pbxproj 의 빌드 설정에 저장됨:
#   MARKETING_VERSION      → CFBundleShortVersionString (예: 1.0.0)
#   CURRENT_PROJECT_VERSION → CFBundleVersion (빌드 번호)
# ---------------------------------------------------------

XCODEPROJ = "Snippet.xcodeproj"
SCHEME    = "Snippet"
IPA_PATH  = File.expand_path("../build/Snippet.ipa", __dir__)

# App Store Connect API Key 인증 (비밀번호 입력 없이 자동화)
# .p8 키 경로/ID는 환경변수로 주입 — 키 파일은 커밋 금지(*.p8 gitignore)
def api_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],           # App Store Connect API Key ID
    issuer_id: ENV["ASC_ISSUER_ID"],     # Issuer ID
    key_filepath: ENV["ASC_KEY_PATH"],   # .p8 파일 경로
    duration: 1200,
    in_house: false
  )
end

def pbxproj_path
  File.expand_path("../Snippet.xcodeproj/project.pbxproj", __dir__)
end

def current_marketing_version
  File.read(pbxproj_path)[/MARKETING_VERSION = ([^;]+);/, 1].strip
end

def current_build_number
  File.read(pbxproj_path)[/CURRENT_PROJECT_VERSION = ([^;]+);/, 1].strip.to_i
end

# marketing/build 가 nil 이면 해당 항목은 그대로 둠. 모든 타깃/컨피그의 값을 함께 갱신.
def set_versions(marketing: nil, build: nil)
  content = File.read(pbxproj_path)
  content = content.gsub(/MARKETING_VERSION = [^;]+;/, "MARKETING_VERSION = #{marketing};") if marketing
  content = content.gsub(/CURRENT_PROJECT_VERSION = [^;]+;/, "CURRENT_PROJECT_VERSION = #{build};") if build
  File.write(pbxproj_path, content)
end

def bump_patch(version)
  parts = version.split(".").map(&:to_i)
  parts << 0 while parts.size < 3
  parts[2] += 1
  parts.take(3).join(".")
end

# Release 컨피그로 아카이브 → app-store 방식으로 IPA export.
# Xcode 자동 서명 + App Store Connect API 키로 배포 인증서/프로파일을 자동 생성·다운로드.
# (이 머신에 Apple Distribution 인증서가 없어도 xcodebuild가 -allowProvisioningUpdates로 처리)
def verify_asc_env!
  {
    "ASC_KEY_ID" => ENV["ASC_KEY_ID"],
    "ASC_ISSUER_ID" => ENV["ASC_ISSUER_ID"],
    "ASC_KEY_PATH" => ENV["ASC_KEY_PATH"]
  }.each do |name, value|
    if value.nil? || value.strip.empty? || value.include?("여기에")
      UI.user_error!("#{name} 가 설정되지 않았습니다. snippet_ios/fastlane/.env 를 확인하세요. (App Store Connect → 사용자 및 액세스 → 통합에서 Issuer ID 확인)")
    end
  end
  key_path = ENV["ASC_KEY_PATH"]
  UI.user_error!(".p8 키 파일을 찾을 수 없습니다: #{key_path}") unless File.exist?(key_path)
end

def signing_xcargs
  # 배포 서명은 Xcode 계정 세션(Xcode → Settings → Accounts 로그인)으로 처리한다.
  # API 키(-authenticationKey*)로 클라우드 서명을 시도하면 키 권한 부족으로
  # "Cloud signing permission error"가 나므로 여기서는 -allowProvisioningUpdates만 사용.
  # (API 키는 아래 upload_to_testflight/app_store 업로드 단계에서만 사용)
  "-allowProvisioningUpdates"
end

def build_ipa
  verify_asc_env!
  build_app(
    project: XCODEPROJ,
    scheme: SCHEME,
    configuration: "Release",
    output_directory: File.expand_path("../build", __dir__),
    output_name: "Snippet.ipa",
    export_method: "app-store",
    export_options: { signingStyle: "automatic" },
    # export 단계에서만 인증 인자 주입 (archive에도 주면 gym이 export에 중복 적용 → 'may only be provided once' 에러)
    export_xcargs: signing_xcargs,
    clean: true
  )
end

# ---------------------------------------------------------
# 릴리즈 노트 자동 생성
# changelogs/{version}.txt가 이미 있으면 그대로 사용(수동 작성이 항상 우선).
# 없으면 직전 릴리즈 태그(v*) 이후의 git log로 자동 생성:
#   1) claude CLI가 있으면 커밋 로그를 사용자 관점 문구로 요약
#   2) 없거나 실패하면 커밋 제목에서 conventional prefix를 떼고 불릿으로 정리
# release lane이 업로드 성공 시 v{version} 태그를 만들어 다음 생성 범위의 기준이 됨.
# ---------------------------------------------------------
def project_root
  File.expand_path("..", __dir__)
end

def last_release_tag
  `git -C "#{project_root}" describe --tags --abbrev=0 --match "v*" 2>/dev/null`.strip
end

def commits_since_last_release
  range = last_release_tag.empty? ? "--max-count=30" : "#{last_release_tag}..HEAD"
  `git -C "#{project_root}" log --no-merges --pretty=format:%s #{range}`
    .lines.map(&:strip)
    .reject(&:empty?)
    .reject { |s| s =~ /^(chore|ci|build|release)[(:!]/i }
end

def previous_changelog_example
  files = Dir[File.expand_path("changelogs/*.txt", __dir__)]
  latest = files.max_by { |f| Gem::Version.new(File.basename(f, ".txt")) rescue Gem::Version.new("0") }
  latest ? File.read(latest).strip : nil
end

def claude_release_notes(commits)
  return nil if `which claude 2>/dev/null`.strip.empty?
  example = previous_changelog_example
  prompt = <<~PROMPT
    다음 git 커밋 제목들을 App Store 한국어 릴리즈 노트로 요약해줘.
    규칙:
    - 사용자 관점의 혜택 중심 문구로. 내부 리팩토링·빌드 설정 변경은 "안정성 및 성능 개선" 한 줄로 묶기
    - 마크다운·코드블록 없이 순수 텍스트만: 첫 줄 소개 문장 + "- " 불릿 목록
    - 전체 500자 이내, 릴리즈 노트 본문만 출력 (부연 설명·서두 금지)
    #{example ? "이전 릴리즈 노트 스타일 예시:\n#{example}\n" : ""}
    커밋 목록:
    #{commits.join("\n")}
  PROMPT
  require "open3"
  UI.message("🤖 claude CLI로 릴리즈 노트 생성 중...")
  out, _err, status = Open3.capture3("claude", "-p", prompt)
  out = out.strip
  status.success? && !out.empty? ? out : nil
rescue StandardError
  nil
end

def fallback_release_notes(commits)
  bullets = commits.map { |c| "- #{c.sub(/^\w+(\([^)]*\))?!?:\s*/, '')}" }
  (["이번 업데이트 내용입니다."] + bullets).join("\n")
end

def generate_release_notes!(version)
  commits = commits_since_last_release
  if commits.empty?
    UI.user_error!(<<~MSG.strip)
      릴리즈 노트를 자동 생성할 커밋이 없습니다 (#{last_release_tag} 태그 이후 새 커밋 0개).
      해결 방법 중 하나를 선택하세요:
        1) 배포할 변경사항을 먼저 커밋한 뒤 다시 실행 (자동 생성은 커밋 메시지를 재료로 씀)
        2) fastlane/changelogs/#{version}.txt를 직접 작성
    MSG
  end

  notes = claude_release_notes(commits) || fallback_release_notes(commits)
  path = File.expand_path("changelogs/#{version}.txt", __dir__)
  File.write(path, notes + "\n")
  UI.important("📝 릴리즈 노트 자동 생성 → fastlane/changelogs/#{version}.txt (업로드 전 수정 가능하도록 파일로 저장됨)")
  UI.message("--------\n#{notes}\n--------")
end

# changelogs/{version}.txt → metadata/ko/release_notes.txt 복사 (없으면 git log로 자동 생성)
def sync_release_notes(version)
  changelog_path = File.expand_path("changelogs/#{version}.txt", __dir__)
  generate_release_notes!(version) unless File.exist?(changelog_path)
  notes = File.read(changelog_path).strip
  UI.user_error!("changelogs/#{version}.txt가 비어있습니다.") if notes.empty?

  require 'fileutils'
  meta_path = File.expand_path("metadata", __dir__)
  FileUtils.mkdir_p("#{meta_path}/ko")
  File.write("#{meta_path}/ko/release_notes.txt", notes)
  meta_path
end

platform :ios do

  # -------------------------------------------------------
  # TestFlight 배포 (버전 bump 없음)
  # 사용법: cd snippet_ios && fastlane beta
  # -------------------------------------------------------
  desc "TestFlight에 빌드 업로드"
  lane :beta do
    build_ipa
    upload_to_testflight(
      api_key: api_key,
      ipa: IPA_PATH,
      skip_waiting_for_build_processing: true
    )
    puts "✅ TestFlight 업로드 완료!"
  end

  # -------------------------------------------------------
  # 빌드 번호 자동 증가 후 TestFlight 배포
  # 사용법: cd snippet_ios && fastlane ship
  # -------------------------------------------------------
  desc "빌드 번호 bump 후 TestFlight 배포"
  lane :ship do
    version   = current_marketing_version
    new_build = current_build_number + 1
    set_versions(build: new_build)
    puts "📦 버전: #{version} (#{new_build})"

    build_ipa
    upload_to_testflight(
      api_key: api_key,
      ipa: IPA_PATH,
      skip_waiting_for_build_processing: true
    )
    puts "✅ v#{version} (#{new_build}) TestFlight 업로드 완료!"
  end

  # -------------------------------------------------------
  # patch 버전 bump 후 App Store 업로드 (심사 제출은 수동)
  # 사용법: cd snippet_ios && fastlane release
  # -------------------------------------------------------
  desc "patch 버전 bump 후 App Store 업로드"
  lane :release do
    new_version = bump_patch(current_marketing_version)
    new_build   = current_build_number + 1

    # 노트 생성이 실패해도 pbxproj 버전이 bump된 채 남지 않도록 bump보다 먼저 실행
    meta_path = sync_release_notes(new_version)

    set_versions(marketing: new_version, build: new_build)
    puts "📦 버전: #{new_version} (#{new_build})"
    build_ipa

    upload_to_app_store(
      api_key: api_key,
      ipa: IPA_PATH,
      app_version: new_version,
      metadata_path: meta_path,
      skip_screenshots: true,
      skip_metadata: false,
      run_precheck_before_submit: false,
      submit_for_review: false,  # true로 바꾸면 자동 심사 제출
      force: true                # HTML 프리뷰 확인 생략 (non-interactive 환경)
    )
    # 다음 릴리즈 노트 자동 생성의 커밋 범위 기준이 되는 태그
    if system("git", "-C", project_root, "tag", "v#{new_version}")
      puts "🏷️  git tag v#{new_version} 생성 (다음 릴리즈 노트 범위 기준)"
    else
      UI.important("git tag v#{new_version} 생성 실패 — 수동으로 태그를 만들어주세요.")
    end

    puts "✅ v#{new_version} (#{new_build}) App Store 업로드 완료! App Store Connect에서 심사 제출하세요."
  end

  # -------------------------------------------------------
  # 프로모션 텍스트만 업데이트 (빌드/심사 없이 즉시 반영)
  # 수정 파일: fastlane/metadata/ko/promotional_text.txt
  # 사용법: cd snippet_ios && fastlane promo
  # -------------------------------------------------------
  desc "프로모션 텍스트 업데이트"
  lane :promo do
    promo_path = File.expand_path("metadata/ko/promotional_text.txt", __dir__)
    UI.user_error!("promotional_text.txt가 없습니다.") unless File.exist?(promo_path)
    UI.user_error!("promotional_text.txt가 비어있습니다.") if File.read(promo_path).strip.empty?

    upload_to_app_store(
      api_key: api_key,
      metadata_path: File.expand_path("metadata", __dir__),
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      run_precheck_before_submit: false,
      submit_for_review: false,
      force: true
    )
    puts "✅ 프로모션 텍스트 업데이트 완료!"
  end

end
